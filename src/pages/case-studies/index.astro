---
import BaseLayout from '../../layouts/BaseLayout.astro';
import { getCollection } from 'astro:content';

const allCaseStudies = await getCollection('case-studies');
const caseStudies = allCaseStudies.sort((a, b) => new Date(b.data.date).getTime() - new Date(a.data.date).getTime());
---

<BaseLayout title="Case Studies — Arjun Suraj L R" description="Deep dives into production AI systems I've built.">
  <section class="mx-auto max-w-5xl px-6 pt-24 pb-16">
    <p class="font-mono text-sm text-[var(--color-accent)] mb-4">Case Studies</p>
    <h1 class="text-3xl md:text-4xl font-bold tracking-tight mb-4">Production stories</h1>
    <p class="text-[var(--color-text-muted)] mb-12 max-w-2xl">
      Detailed write-ups on projects I've shipped — the problem, the approach,
      architecture decisions, and what I learned.
    </p>

    <div class="space-y-8">
      {caseStudies.map(cs => (
        <a href={`/case-studies/${cs.id}`} class="group block p-6 rounded-xl border border-[var(--color-border)] bg-[var(--color-bg-alt)] hover:border-[var(--color-accent)]/40 transition-colors">
          <div class="flex flex-col md:flex-row md:items-start md:justify-between gap-4">
            <div class="flex-1">
              <div class="flex items-center gap-3 mb-2">
                <span class="text-xs font-mono text-[var(--color-accent)]">{cs.data.company}</span>
                <span class="text-xs text-[var(--color-text-muted)]">&middot;</span>
                <span class="text-xs text-[var(--color-text-muted)]">{cs.data.role}</span>
              </div>
              <h3 class="text-lg font-semibold mb-2 group-hover:text-[var(--color-accent)] transition-colors">{cs.data.title}</h3>
              <p class="text-sm text-[var(--color-text-muted)] mb-3">{cs.data.description}</p>
              <div class="flex flex-wrap gap-2">
                {cs.data.tags.map(tag => (
                  <span class="text-xs px-2 py-1 rounded-md bg-[var(--color-tag-bg)] text-[var(--color-tag-text)] font-mono">{tag}</span>
                ))}
              </div>
            </div>
            <div class="md:text-right shrink-0">
              <p class="text-sm font-medium text-[var(--color-text)]">{cs.data.impact}</p>
              <p class="text-xs text-[var(--color-text-muted)] mt-1 font-mono">{cs.data.date}</p>
            </div>
          </div>
        </a>
      ))}
    </div>
  </section>
</BaseLayout>
