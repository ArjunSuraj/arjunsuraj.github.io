---
import BaseLayout from '../layouts/BaseLayout.astro';
import { getCollection } from 'astro:content';

const allProjects = await getCollection('projects');
const featuredProjects = allProjects
  .filter(p => p.data.featured)
  .sort((a, b) => (a.data.order ?? 0) - (b.data.order ?? 0))
  .slice(0, 3);

const allPosts = await getCollection('blog');
const recentPosts = allPosts
  .filter(p => !p.data.draft)
  .sort((a, b) => new Date(b.data.date).getTime() - new Date(a.data.date).getTime())
  .slice(0, 3);

const allCaseStudies = await getCollection('case-studies');
const featuredCaseStudies = allCaseStudies
  .filter(cs => cs.data.featured)
  .slice(0, 2);
---

<BaseLayout title="Arjun Suraj L R — AI Engineer">
  <!-- Hero -->
  <section class="mx-auto max-w-5xl px-6 pt-24 pb-16">
    <p class="font-mono text-sm text-[var(--color-accent)] mb-4">Hi, I'm</p>
    <h1 class="text-4xl md:text-6xl font-bold tracking-tight mb-4">
      Arjun Suraj L R
    </h1>
    <h2 class="text-xl md:text-2xl text-[var(--color-text-muted)] font-medium mb-6">
      AI Engineer building production ML systems
    </h2>
    <p class="text-[var(--color-text-muted)] max-w-2xl mb-8 leading-relaxed">
      7+ years shipping enterprise software across finance, insurance, and supply chain.
      Now leading code generation and RAG initiatives at Trimble — turning LLMs into
      developer productivity tools that work at scale.
    </p>
    <div class="flex gap-4">
      <a href="/projects" class="inline-flex items-center gap-2 px-5 py-2.5 rounded-lg bg-[var(--color-accent)] text-white text-sm font-medium hover:bg-[var(--color-accent-hover)] transition-colors">
        View Projects
        <svg class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path d="M5 12h14M12 5l7 7-7 7"/></svg>
      </a>
      <a href="/contact" class="inline-flex items-center gap-2 px-5 py-2.5 rounded-lg border border-[var(--color-border)] text-sm font-medium text-[var(--color-text)] hover:bg-[var(--color-tag-bg)] transition-colors">
        Get in Touch
      </a>
    </div>
  </section>

  <!-- Featured Projects -->
  {featuredProjects.length > 0 && (
    <section class="mx-auto max-w-5xl px-6 py-16 border-t border-[var(--color-border)]">
      <div class="flex items-center justify-between mb-8">
        <h2 class="text-2xl font-bold">Featured Projects</h2>
        <a href="/projects" class="text-sm text-[var(--color-accent)] hover:underline">View all &rarr;</a>
      </div>
      <div class="grid md:grid-cols-3 gap-6">
        {featuredProjects.map(project => (
          <a href={`/projects/${project.id}`} class="group block p-6 rounded-xl border border-[var(--color-border)] bg-[var(--color-bg-alt)] hover:border-[var(--color-accent)]/40 transition-colors">
            <h3 class="font-semibold mb-2 group-hover:text-[var(--color-accent)] transition-colors">{project.data.title}</h3>
            <p class="text-sm text-[var(--color-text-muted)] mb-4 line-clamp-2">{project.data.description}</p>
            <div class="flex flex-wrap gap-2">
              {project.data.tags.slice(0, 3).map(tag => (
                <span class="text-xs px-2 py-1 rounded-md bg-[var(--color-tag-bg)] text-[var(--color-tag-text)] font-mono">{tag}</span>
              ))}
            </div>
          </a>
        ))}
      </div>
    </section>
  )}

  <!-- Featured Case Studies -->
  {featuredCaseStudies.length > 0 && (
    <section class="mx-auto max-w-5xl px-6 py-16 border-t border-[var(--color-border)]">
      <div class="flex items-center justify-between mb-8">
        <h2 class="text-2xl font-bold">Case Studies</h2>
        <a href="/case-studies" class="text-sm text-[var(--color-accent)] hover:underline">View all &rarr;</a>
      </div>
      <div class="grid md:grid-cols-2 gap-6">
        {featuredCaseStudies.map(cs => (
          <a href={`/case-studies/${cs.id}`} class="group block p-6 rounded-xl border border-[var(--color-border)] bg-[var(--color-bg-alt)] hover:border-[var(--color-accent)]/40 transition-colors">
            <p class="text-xs font-mono text-[var(--color-accent)] mb-2">{cs.data.company}</p>
            <h3 class="font-semibold mb-2 group-hover:text-[var(--color-accent)] transition-colors">{cs.data.title}</h3>
            <p class="text-sm text-[var(--color-text-muted)] mb-3 line-clamp-2">{cs.data.description}</p>
            <p class="text-xs text-[var(--color-text-muted)]">{cs.data.impact}</p>
          </a>
        ))}
      </div>
    </section>
  )}

  <!-- Recent Blog Posts -->
  {recentPosts.length > 0 && (
    <section class="mx-auto max-w-5xl px-6 py-16 border-t border-[var(--color-border)]">
      <div class="flex items-center justify-between mb-8">
        <h2 class="text-2xl font-bold">Latest Posts</h2>
        <a href="/blog" class="text-sm text-[var(--color-accent)] hover:underline">View all &rarr;</a>
      </div>
      <div class="flex flex-col gap-6">
        {recentPosts.map(post => (
          <a href={`/blog/${post.id}`} class="group flex items-start justify-between gap-4 p-4 -mx-4 rounded-lg hover:bg-[var(--color-bg-alt)] transition-colors">
            <div>
              <h3 class="font-medium group-hover:text-[var(--color-accent)] transition-colors">{post.data.title}</h3>
              <p class="text-sm text-[var(--color-text-muted)] mt-1">{post.data.description}</p>
            </div>
            <time class="text-sm text-[var(--color-text-muted)] whitespace-nowrap font-mono">
              {new Date(post.data.date).toLocaleDateString('en-US', { month: 'short', day: 'numeric', year: 'numeric' })}
            </time>
          </a>
        ))}
      </div>
    </section>
  )}
</BaseLayout>
