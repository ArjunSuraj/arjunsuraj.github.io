---
import BaseLayout from '../../layouts/BaseLayout.astro';
import { getCollection } from 'astro:content';

const allPosts = await getCollection('blog');
const posts = allPosts
  .filter(p => !p.data.draft)
  .sort((a, b) => new Date(b.data.date).getTime() - new Date(a.data.date).getTime());

const allTags = [...new Set(posts.flatMap(p => p.data.tags))].sort();
---

<BaseLayout title="Blog — Arjun Suraj L R" description="Writing about AI engineering, RAG, code generation, and building production systems.">
  <section class="mx-auto max-w-5xl px-6 pt-24 pb-16">
    <p class="font-mono text-sm text-[var(--color-accent)] mb-4">Blog</p>
    <h1 class="text-3xl md:text-4xl font-bold tracking-tight mb-4">Writing</h1>
    <p class="text-[var(--color-text-muted)] mb-8 max-w-2xl">
      Thoughts on AI engineering, lessons from building production systems,
      and things I'm learning along the way.
    </p>

    {allTags.length > 0 && (
      <div class="flex flex-wrap gap-2 mb-10">
        {allTags.map(tag => (
          <span class="text-xs px-2 py-1 rounded-md bg-[var(--color-tag-bg)] text-[var(--color-tag-text)] font-mono">{tag}</span>
        ))}
      </div>
    )}

    <div class="space-y-1">
      {posts.map(post => (
        <a href={`/blog/${post.id}`} class="group flex items-start justify-between gap-4 p-4 -mx-4 rounded-lg hover:bg-[var(--color-bg-alt)] transition-colors">
          <div>
            <h3 class="font-medium group-hover:text-[var(--color-accent)] transition-colors">{post.data.title}</h3>
            <p class="text-sm text-[var(--color-text-muted)] mt-1">{post.data.description}</p>
            <div class="flex flex-wrap gap-2 mt-2">
              {post.data.tags.map(tag => (
                <span class="text-[11px] px-1.5 py-0.5 rounded bg-[var(--color-tag-bg)] text-[var(--color-tag-text)] font-mono">{tag}</span>
              ))}
            </div>
          </div>
          <time class="text-sm text-[var(--color-text-muted)] whitespace-nowrap font-mono shrink-0">
            {new Date(post.data.date).toLocaleDateString('en-US', { month: 'short', day: 'numeric', year: 'numeric' })}
          </time>
        </a>
      ))}
    </div>

    {posts.length === 0 && (
      <div class="text-center py-20">
        <p class="text-[var(--color-text-muted)]">No posts yet. Check back soon.</p>
      </div>
    )}
  </section>
</BaseLayout>
