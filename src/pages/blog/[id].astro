---
import BaseLayout from '../../layouts/BaseLayout.astro';
import { getCollection, render } from 'astro:content';

export async function getStaticPaths() {
  const posts = await getCollection('blog');
  return posts.map(post => ({
    params: { id: post.id },
    props: { post },
  }));
}

const { post } = Astro.props;
const { Content } = await render(post);
---

<BaseLayout title={`${post.data.title} — Arjun Suraj L R`} description={post.data.description}>
  <article class="mx-auto max-w-3xl px-6 pt-24 pb-16">
    <a href="/blog" class="inline-flex items-center gap-1 text-sm text-[var(--color-text-muted)] hover:text-[var(--color-accent)] transition-colors mb-8">
      <svg class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path d="M19 12H5M12 19l-7-7 7-7"/></svg>
      All Posts
    </a>

    <time class="text-sm font-mono text-[var(--color-text-muted)] mb-4 block">
      {new Date(post.data.date).toLocaleDateString('en-US', { month: 'long', day: 'numeric', year: 'numeric' })}
    </time>

    <h1 class="text-3xl md:text-4xl font-bold tracking-tight mb-4">{post.data.title}</h1>
    <p class="text-lg text-[var(--color-text-muted)] mb-6">{post.data.description}</p>

    <div class="flex flex-wrap gap-2 mb-10 pb-6 border-b border-[var(--color-border)]">
      {post.data.tags.map(tag => (
        <span class="text-xs px-2 py-1 rounded-md bg-[var(--color-tag-bg)] text-[var(--color-tag-text)] font-mono">{tag}</span>
      ))}
    </div>

    <div class="prose">
      <Content />
    </div>
  </article>
</BaseLayout>
